{
  "manifest_version": 3,
  "name": "Cloud Cost Tracker",
  "description": "A sidebar calculator for cloud compute costs.",
  "version": "1.0.0",
  "permissions": ["storage", "scripting", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Cloud Cost Tracker",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/logo.png",
      "48": "assets/logo.png",
      "128": "assets/logo.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "sidebar/sidebar.js",
        "sidebar/sidebar-template.js",
        "sidebar/pricing-engine.js",
        "sidebar/pricing-data.js",
        "sidebar/pricing-service.js",
        "data/aws-ec2-pricing.json",
        "data/aws-rds-pricing.json",
        "data/aws-lambda-pricing.json",
        "data/aws-s3-pricing.json",
        "sidebar/sidebar.css",
        "utils/helpers.js",
        "utils/constants.js",
        "popup.html",
        "popup.js",
        "assets/logo.png"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "assets/logo.png",
    "48": "assets/logo.png",
    "128": "assets/logo.png"
  }
}
